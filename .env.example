# Required: OpenAI powers both generation and embeddings
OPENAI_API_KEY=sk..
# Chat model (must support Structured Outputs: gpt-4o, gpt-4o-mini, gpt-4.1, ...)
OPENAI_MODEL=gpt-4o

# Embeddings
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
TOP_K=5
HYBRID_SEARCH=true

# Chunking
CHUNK_TOKENS=500
CHUNK_OVERLAP=0.15

# API
PORT=8000
